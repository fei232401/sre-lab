          "expr": "scheduler_backend_tps",
          "legendFormat": "{{backend}}"
        }
      ]
    },
    {
      "title": "熔断器状态",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 31
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "scheduler_backend_circuit_breaker",
          "legendFormat": "{{backend}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 2,
