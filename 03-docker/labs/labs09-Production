services:
  redis:
    image: redis
    healthcheck:
      test: ["CMD","redis-cli","ping"]
      interval: 5s
      timeout: 3s
      retries: 5
      start_period: 5s
    networks:
      - backend

  mysql:
    image: mysql:8
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
    healthcheck:
      test: ["CMD","mysqladmin","ping","-h","localhost"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 20s
    volumes:
      - mysql_data:/var/lib/mysql
    networks:
      - backend

  nginx:
    image: nginx
    ports:
      - "80:80"
    depends_on:
      redis:
        condition: service_started
      mysql:
        condition: service_started
    networks:
      - frontend
      - backend
networks:
  frontend:
  backend:
volumes:
  mysql_data:
